---
import { site } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} · ${site.name}` : site.name;
const pageDesc = description ?? site.tagline;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@500;600;700&display=swap" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="invocation" aria-label="Shree Krushna Sadaa Sahaayate">
      <span class="sk">॥ श्री कृष्ण सदा सहायते ॥</span>
      <span class="sk-en">Shree Krushna Sadaa Sahaayate</span>
    </div>
    <header class="site-header">
      <a href="/" class="brand">{site.name}</a>
      <nav>
        <a href="/">Home</a>
        <a href="/experience">Experience</a>
        <a href="/projects">Projects</a>
        <a href="/writing">Writing</a>
        <a href="/now">Now</a>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-top">
          <span>&copy; {new Date().getFullYear()} {site.name}</span>
          <span class="links">
            {site.github && <a href={site.github}>GitHub</a>}
            {site.linkedin && <a href={site.linkedin}>LinkedIn</a>}
            {site.email && <a href={`mailto:${site.email}`}>Email</a>}
          </span>
        </div>
        <div class="footer-mark">
          <img src="/mustang.png" alt="Mustang" />
        </div>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #0a1733;
        --bg-2: #0d1f44;
        --panel: #122a55;
        --text: #eef2ff;
        --muted: #a8b4d0;
        --accent: #6ea8ff;
        --accent-2: #f3c969;
        --border: #1f3a6d;
        --radius: 12px;
        --max: 820px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background:
          radial-gradient(1200px 600px at 80% -10%, rgba(110,168,255,0.10), transparent 60%),
          radial-gradient(900px 500px at -10% 30%, rgba(243,201,105,0.06), transparent 60%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
        background-attachment: fixed;
        color: var(--text);
        line-height: 1.65;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
        position: relative;
        min-height: 100vh;
      }
      /* Krishna's peacock feather, subtle background mark */
      body::before {
        content: '';
        position: fixed;
        top: -40px;
        right: -60px;
        width: 320px;
        height: 900px;
        background-image: url('/peacock-feather.svg');
        background-repeat: no-repeat;
        background-size: contain;
        background-position: top right;
        opacity: 0.18;
        transform: rotate(18deg);
        pointer-events: none;
        z-index: 0;
        filter: drop-shadow(0 0 24px rgba(110,168,255,0.25));
      }
      @media (max-width: 720px) {
        body::before { opacity: 0.10; width: 220px; }
      }
      .invocation, .site-header, main, .site-footer { position: relative; z-index: 1; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1, h2, h3 { line-height: 1.25; margin: 1.6em 0 0.6em; }
      h1 { font-size: 2.2rem; margin-top: 0; }
      h2 { font-size: 1.5rem; }
      h3 { font-size: 1.15rem; }
      p { margin: 0 0 1em; color: var(--text); }
      .muted { color: var(--muted); }
      .container { max-width: var(--max); margin: 0 auto; padding: 32px 24px 80px; }
      code { background: rgba(255,255,255,0.06); padding: 2px 6px; border-radius: 6px; font-size: 0.92em; }
      hr { border: 0; border-top: 1px solid var(--border); margin: 32px 0; }

      .invocation {
        text-align: center;
        padding: 16px 16px 14px;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(243,201,105,0.12), rgba(243,201,105,0.02));
        color: var(--accent-2);
        letter-spacing: 0.4px;
        font-size: 1.5rem;
      }
      .invocation .sk {
        font-family: 'Noto Sans Devanagari', 'Mangal', serif;
        font-weight: 600;
        margin-right: 14px;
        text-shadow: 0 0 22px rgba(243,201,105,0.45);
      }
      .invocation .sk-en { color: var(--muted); font-style: italic; font-size: 0.95rem; }
      @media (max-width: 520px) { .invocation .sk-en { display: block; margin-top: 2px; } }

      .site-header {
        display: flex; align-items: center; justify-content: space-between;
        max-width: var(--max); margin: 0 auto; padding: 24px;
        border-bottom: 1px solid var(--border);
      }
      .site-header .brand { color: var(--text); font-weight: 600; }
      .site-header nav { display: flex; gap: 18px; }
      .site-header nav a { color: var(--muted); }
      .site-header nav a:hover { color: var(--text); text-decoration: none; }

      .site-footer {
        border-top: 1px solid var(--border);
        padding: 24px 0 32px;
        color: var(--muted);
        font-size: 0.9rem;
      }
      .site-footer .container {
        padding-top: 16px; padding-bottom: 0;
      }
      .site-footer .footer-top {
        display: flex; justify-content: space-between; align-items: center;
      }
      .site-footer .links a { color: var(--muted); margin-left: 16px; }
      .footer-mark {
        margin-top: 18px;
        display: flex; justify-content: center;
        opacity: 0.78;
      }
      .footer-mark img {
        max-width: 140px; height: auto;
        filter: drop-shadow(0 4px 14px rgba(110,168,255,0.18));
      }

      /* Cards */
      .card {
        display: block;
        background: rgba(18, 42, 85, 0.55);
        backdrop-filter: blur(6px);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px 22px;
        margin: 14px 0;
        color: var(--text);
        text-decoration: none;
        transition: border-color .15s, transform .15s, background .15s;
      }
      .card:hover { border-color: var(--accent); text-decoration: none; transform: translateY(-2px); background: rgba(18, 42, 85, 0.85); }
      .card h3 { margin: 0 0 6px; }
      .card .tagline { color: var(--muted); margin: 0 0 12px; }
      .card .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
      .tag { font-size: 0.75rem; padding: 3px 8px; background: rgba(10,23,51,0.6); border: 1px solid var(--border); border-radius: 999px; color: var(--muted); }

      .hero { padding: 30px 0 10px; }
      .hero h1 { font-size: 2.6rem; }
      .hero .lead { font-size: 1.2rem; color: var(--muted); max-width: 640px; }
    </style>
  </body>
</html>
